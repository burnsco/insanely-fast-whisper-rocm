# Insanely Fast Whisper ROCm
# Copy to ~/.config/insanely-fast-whisper-rocm/.env and adjust as needed.

# ---------------------------------------------------------------------------
# Core model/runtime defaults
# ---------------------------------------------------------------------------

WHISPER_MODEL=distil-whisper/distil-large-v3.5

# Use "0" for the first ROCm GPU. PyTorch still maps ROCm devices to cuda:N.
WHISPER_DEVICE=0
WHISPER_BATCH_SIZE=4
WHISPER_DTYPE=float16
WHISPER_CONDITION_ON_PREV_TOKENS=true
WHISPER_SEQUENTIAL_LONG_FORM=false
WHISPER_CHUNK_LENGTH=30
WHISPER_TIMESTAMP_TYPE=word
WHISPER_LANGUAGE=None
PROGRESS_GROUP_SIZE=4

# ---------------------------------------------------------------------------
# Timestamp stabilization defaults
# ---------------------------------------------------------------------------

STABILIZE_DEFAULT=false
DEMUCS_DEFAULT=false
VAD_DEFAULT=false
VAD_THRESHOLD_DEFAULT=0.35
SUPPRESS_TS_TOKENS_DEFAULT=true
GAP_PADDING_DEFAULT=" ..."
ADJUST_GAPS_DEFAULT=true
NONSPEECH_SKIP_DEFAULT=

# ---------------------------------------------------------------------------
# Subtitle synchronization defaults (ALASS)
# ---------------------------------------------------------------------------

SUBTITLE_SYNC_DEFAULT=true
ALASS_BINARY=alass
ALASS_TIMEOUT_SECONDS=180
ALASS_SPLIT_PENALTY=7
ALASS_NO_SPLITS=false

# ---------------------------------------------------------------------------
# Output and filesystem defaults
# ---------------------------------------------------------------------------

WHISPER_UPLOAD_DIR=data/temp_uploads
WHISPER_TRANSCRIPTS_DIR=data/transcripts
SAVE_TRANSCRIPTIONS=true
APP_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# API and optional Gradio UI
# ---------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8888
DEV_API_PORT=8889

WEBUI_HOST=0.0.0.0
WEBUI_PORT=7860
DEV_WEBUI_PORT=7862

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Subtitle readability defaults
# ---------------------------------------------------------------------------

USE_READABLE_SUBTITLES=true
MAX_LINE_CHARS=42
MAX_LINES_PER_BLOCK=2
MAX_BLOCK_CHARS=84
MAX_BLOCK_CHARS_SOFT=90
MIN_CPS=12.0
MAX_CPS=17.0
MIN_SEGMENT_DURATION_SEC=1.2
MAX_SEGMENT_DURATION_SEC=5.5
DISPLAY_BUFFER_SEC=0.2
SOFT_BOUNDARY_WORDS=and,but,or,so,for,nor,yet
INTERJECTION_WHITELIST=um,uh,ah,er,like

# ---------------------------------------------------------------------------
# Optional ROCm tuning
# ---------------------------------------------------------------------------

ROCM_PATH=/opt/rocm
PYTORCH_ALLOC_CONF=garbage_collection_threshold:0.7,max_split_size_mb:128
# HSA_OVERRIDE_GFX_VERSION=10.3.0
# HIP_LAUNCH_BLOCKING=true
TORCHAUDIO_USE_SOUNDFILE=1

# ---------------------------------------------------------------------------
# Optional Hugging Face credentials / cache
# ---------------------------------------------------------------------------

# HF_TOKEN=hf_your_token_here
# HF_HOME=/path/to/hf-home
# HUGGINGFACE_HUB_CACHE=/path/to/hf-home/hub
